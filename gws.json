{
  "name": "pern-stack",
  "version": "1.0.0",
  "registry": {
    "mode": "in-cluster"
  },
  "profiles": {
    "qa": {
      "services": [
        {
          "name": "*",
          "fileSync": false
        }
      ],
      "description": "QA runs — static images, no file sync (managed by /gws-qa; edit freely)"
    }
  },
  "services": [
    {
      "name": "server",
      "path": "./server",
      "port": 5000,
      "hosts": [
        "server.pern-stack.local.getwebstack.dev"
      ],
      "fileSync": true,
      "manifests": ".gws/services/server/k8s",
      "dockerfile": ".gws/services/server/Dockerfile",
      "fileSyncIgnore": [
        "node_modules/",
        "dist/",
        "coverage/",
        "*.log",
        "/.git",
        "/.idea",
        "/.vscode"
      ]
    },
    {
      "name": "client",
      "path": "./client",
      "port": 5173,
      "hosts": [
        "client.pern-stack.local.getwebstack.dev"
      ],
      "fileSync": true,
      "manifests": ".gws/services/client/k8s",
      "dockerfile": ".gws/services/client/Dockerfile",
      "fileSyncIgnore": [
        "node_modules/",
        "dist/",
        "coverage/",
        "*.log",
        "/.git",
        "/.idea",
        "/.vscode"
      ]
    },
    {
      "name": "postgresql",
      "path": "./postgresql",
      "port": 5432,
      "fileSync": false,
      "manifests": ".gws/services/postgresql/k8s"
    }
  ]
}