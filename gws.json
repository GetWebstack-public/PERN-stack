{
  "name": "pern-stack",
  "version": "1.0.0",
  "registry": {
    "mode": "in-cluster"
  },
  "services": [
    {
      "name": "server",
      "path": "./server",
      "port": 5000,
      "hosts": [
        "server.pern-stack.atlas.getwebstack.dev"
      ],
      "fileSync": true,
      "dockerfile": ".gws/services/server/Dockerfile",
      "dependsOn": ["postgresql"],
      "env": {
        "PORT": "5000",
        "NODE_ENV": "development",
        "DATABASE_URL": "postgresql://devuser:devpassword@postgresql:5432/pern_dev",
        "CLIENT_URL": "https://client.pern-stack.atlas.getwebstack.dev"
      },
      "fileSyncIgnore": ["node_modules/", "dist/", "coverage/", "*.log", "/.git", "/.idea", "/.vscode"]
    },
    {
      "name": "client",
      "path": "./client",
      "port": 5173,
      "hosts": [
        "client.pern-stack.atlas.getwebstack.dev"
      ],
      "fileSync": true,
      "dockerfile": ".gws/services/client/Dockerfile",
      "command": ["sh", "-c", "until [ -f index.html ]; do sleep 1; done && npm install && npm run dev"],
      "fileSyncIgnore": ["node_modules/", "dist/", "coverage/", "*.log", "/.git", "/.idea", "/.vscode"]
    },
    {
      "name": "postgresql",
      "path": "./postgresql",
      "datastore": {
        "engine": "postgres",
        "database": "pern_dev",
        "user": "devuser",
        "password": "devpassword"
      }
    }
  ],
  "profiles": {
    "qa": {
      "description": "QA runs — production-like self-contained images that bake in source, no file sync (used by /gws-qa-run).",
      "services": [
        {
          "name": "server",
          "fileSync": false,
          "dockerfile": "Dockerfile.qa"
        },
        {
          "name": "client",
          "fileSync": false,
          "dockerfile": "Dockerfile.qa",
          "command": ["nginx", "-g", "daemon off;"],
          "buildArgs": { "VITE_API_URL": "https://server.pern-stack.atlas.getwebstack.dev/api" }
        }
      ]
    }
  }
}
