{
  "name": "pern-stack",
  "version": "1.0.0",
  "registry": {
    "mode": "local"
  },
  "services": [
    {
      "name": "server",
      "path": "./server",
      "port": 5000,
      "fileSync": true,
      "dockerfile": ".gws/services/server/Dockerfile",
      "dependsOn": ["postgresql"],
      "env": {
        "PORT": "5000",
        "NODE_ENV": "development",
        "DATABASE_URL": "postgresql://devuser:devpassword@postgresql:5432/pern_dev",
        "CLIENT_URL": "https://client.pern-stack.vlad-nistorica.getwebstack.dev:9443"
      },
      "fileSyncIgnore": ["node_modules/", "dist/", "coverage/", "*.log", "/.git", "/.idea", "/.vscode"]
    },
    {
      "name": "client",
      "path": "./client",
      "port": 5173,
      "fileSync": true,
      "dockerfile": ".gws/services/client/Dockerfile",
      "command": ["sh", "-c", "until [ -f index.html ]; do sleep 1; done && npm install && npx --no vite --host 0.0.0.0"],
      "fileSyncIgnore": ["node_modules/", "dist/", "coverage/", "*.log", "/.git", "/.idea", "/.vscode"]
    },
    {
      "name": "postgresql",
      "path": "./postgresql",
      "datastore": {
        "engine": "postgres",
        "database": "pern_dev",
        "user": "devuser",
        "password": "devpassword"
      }
    }
  ],
  "profiles": {
    "qa": {
      "description": "QA runs — static images, no file sync (managed by /gws-qa-run; edit freely)",
      "services": [
        { "name": "*", "fileSync": false }
      ]
    }
  }
}
